# ============================================================
# DOCKER/CONTAINER KERNEL CONFIG - MINIMAL
# Only configs NOT already in stock gki_defconfig
# ============================================================

# === CGROUP_DEVICE (MISSING in stock - Docker REQUIRES this) ===
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_MISC=y

# === USER NS (MISSING in stock - needed for rootless Docker) ===
CONFIG_USER_NS=y

# === DM_THIN_PROVISIONING (MISSING in stock - Docker storage) ===
CONFIG_DM_THIN_PROVISIONING=y

# === ANDROID PARANOID NETWORK (disable - blocks Docker networking) ===
CONFIG_ANDROID_PARANOID_NETWORK=n

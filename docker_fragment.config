# ============================================================
# DOCKER/CONTAINER KERNEL CONFIG - Pixel 8a (akita) GKI 6.1
# Based on research: WildKernel, deepongi, Docker docs
# ============================================================

# === CGROUP_DEVICE (Docker REQUIRED - missing in stock) ===
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_MISC=y

# === USER NS (Docker rootless - missing in stock) ===
CONFIG_USER_NS=y

# === DM_THIN_PROVISIONING (Docker storage - missing in stock) ===
CONFIG_DM_THIN_PROVISIONING=y

# === NETFILTER advanced (Docker networking) ===
CONFIG_NETFILTER_XT_MATCH_IPVS=y
CONFIG_IP_VS=y
CONFIG_IP_VS_NFCT=y
CONFIG_IP_VS_RR=y
CONFIG_IP_VS_WRR=y
CONFIG_IP_VS_SH=y
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y

# === IPSet (advanced firewall - Docker swarm) ===
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_IP_SET_HASH_IPPORT=y
CONFIG_IP_SET_HASH_IPPORTIP=y
CONFIG_IP_SET_HASH_IPPORTNET=y
CONFIG_NETFILTER_XT_SET=y

# === Network QoS (better Docker networking) ===
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_DEFAULT=fq_codel
CONFIG_DEFAULT_NET_SCH=fq_codel

# === TCP BBR (better throughput) ===
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG=bbr

# === ANDROID PARANOID NETWORK (disable - blocks Docker) ===
CONFIG_ANDROID_PARANOID_NETWORK=n

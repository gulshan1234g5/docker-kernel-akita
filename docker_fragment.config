# ============================================================
# DOCKER/CONTAINER KERNEL CONFIG - Pixel 8a GKI 6.1
# Verified with Docker check-config.sh + kernel olddefconfig
# ============================================================

# REQUIRED by Docker (missing in stock GKI defconfig)
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_MISC=y
CONFIG_USER_NS=y
CONFIG_DM_THIN_PROVISIONING=y

# Docker IPv6 NAT (missing in stock)
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y

# Docker network classification
CONFIG_NET_CLS_CGROUP=y
CONFIG_CFS_BANDWIDTH=y

# IPVS - Docker Swarm load balancing
CONFIG_IP_VS=y
CONFIG_IP_VS_NFCT=y
CONFIG_IP_VS_RR=y
CONFIG_IP_VS_WRR=y
CONFIG_IP_VS_SH=y
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y

# IPSet - advanced firewall
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y

# Network performance - BBR + FQ-CoDel
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_DEFAULT="fq_codel"

# CRITICAL: Disable Android paranoid network (blocks Docker)
CONFIG_ANDROID_PARANOID_NETWORK=n

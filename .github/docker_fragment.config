# ============================================================
# ULTIMATE DOCKER/CONTAINER KERNEL CONFIG
# Source: Droidspaces-OSS + AVF-Android + Xiaomi Docker Kernel
# Device: Pixel 8a (akita) — GKI 6.1
# ============================================================

# === IPC MECHANISMS (Required for containers) ===
CONFIG_SYSCTL=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y

# === CORE NAMESPACES (Required for containers) ===
CONFIG_NAMESPACES=y
CONFIG_PID_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y

# === SECCOMP (Security filtering) ===
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# === CONTROL GROUPS (Required for Docker) ===
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_MEMCG_SWAP_ENABLED=y
CONFIG_MEMCG_V1=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_CGROUP_RWSTAT=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_WRITEBACK=y

# === DEVICE FILESYSTEM (Required for /dev) ===
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# === OVERLAY FILESYSTEM (Required for Docker layers) ===
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_METACOPY=y

# === BLOCK DEVICE MANAGEMENT (Docker storage) ===
CONFIG_BLK_DEV_DM=y
CONFIG_DM_THIN_PROVISIONING=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_NBD=y

# === VIRTUAL ETHERNET (Docker networking) ===
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_BRIDGE_VLAN_FILTERING=y

# === NETWORK NAMESPACE (Docker NAT) ===
CONFIG_NET_NS=y
CONFIG_IPVLAN=y
CONFIG_MACVLAN=y
CONFIG_VXLAN=y
CONFIG_DUMMY=y
CONFIG_TUN=y
CONFIG_VTUN=y

# === NETFILTER (Firewall/NAT) ===
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_IPV4=y
CONFIG_NF_CONNTRACK_NETLINK=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_NAT_IPV4=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_TCPMSS=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y

# === NFTABLES (Modern firewall) ===
CONFIG_NF_TABLES=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_CT=y
CONFIG_NFT_FIB=y
CONFIG_NFT_FIB_IPV4=y
CONFIG_NFT_FIB_IPV6=y

# === IPV6 NETWORKING ===
CONFIG_IPV6=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y

# === ADVANCED ROUTING ===
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y

# === IPVS (Load balancing for Docker Swarm) ===
CONFIG_IP_VS=y
CONFIG_IP_VS_NFCT=y
CONFIG_IP_VS_RR=y
CONFIG_IP_VS_WRR=y
CONFIG_IP_VS_SH=y
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y

# === LEGACY COMPAT ===
CONFIG_NF_CONNTRACK_IPV4=y
CONFIG_NF_NAT_IPV4=y
CONFIG_IP_NF_NAT=y

# === ANDROID FIX ===
CONFIG_ANDROID_PARANOID_NETWORK=n

# === TMPFS EXTENDED ATTRIBUTES (NixOS support) ===
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y

# === FIRMWARE LOADING ===
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_USER_HELPER=y
CONFIG_FW_LOADER_COMPRESS=y

# === ZRAM (Compressed swap) ===
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_MULTI_COMP=y
CONFIG_ZRAM_BACKEND_ZSTD=y

# === ZSWAP (Compressed cache) ===
CONFIG_ZSWAP=y
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_ZSWAP_SHRINKER_DEFAULT_ON=y

# === SWAP ===
CONFIG_SWAP=y
CONFIG_SWAP_ZRAM=y
CONFIG_SWAP_ZRAM_WRITEBACK=y

# === TRANSPARENT HUGE PAGES ===
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_THP_SWAP=y

# === MEMORY MANAGEMENT ===
CONFIG_CMA=y
CONFIG_CMA_SIZE_MBYTES=64
CONFIG_CONTIG_ALLOC=y
CONFIG_BUDDY_ALLOC=y
CONFIG_PAGE_REPORTING=y
CONFIG_KSM=y
CONFIG_DEFAULT_MMAP_MIN_ADDR=32768
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=n
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y

# === SCHEDULER TUNING ===
CONFIG_SCHED_AUTOGROUP=y
CONFIG_SCHED_TUNE=y
CONFIG_HZ_300=y
CONFIG_HZ=300
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=y

# === I/O SCHEDULER ===
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_MQ_IOSCHED_BFQ=y
CONFIG_DEFAULT_MQ_IOSCHED="bfq"

# === BPF (Advanced networking) ===
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_CGROUP_BPF=y
CONFIG_BPF_LSM=y

# === NETWORK PERFORMANCE ===
CONFIG_NET_SCHED=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_SFQ=y
CONFIG_DEFAULT_NET_SCH="fq_codel"
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_TARGET_REJECT=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_NETFILTER_XT_TARGET_LOG=y

# === IP SET (UFW/Fail2ban support) ===
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_NETLINK_QUEUE=y
CONFIG_NETFILTER_NETLINK_LOG=y
CONFIG_NETFILTER_XT_TARGET_NFLOG=y

# === SECURITY ===
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_YAMA=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# === FILESYSTEM SUPPORT ===
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_XFS_FS=y
CONFIG_F2FS_FS=y
CONFIG_NTFS3_FS=y

# === CRYPTO (for Docker) ===
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_LZO=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_ZSTD=y

# === IPC MECHANISMS (for systemd) ===
CONFIG_EPOLL=y
CONFIG_EVENTFD=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y

# === PROCESS ACCOUNTING ===
CONFIG_TASKSTATS=y
CONFIG_TASK_DELAY_ACCT=y
CONFIG_TASK_XACCT=y
CONFIG_TASK_IO_ACCOUNTING=y
CONFIG_PSI=y

# === NESTED CONTAINERS (Docker in Docker) ===
CONFIG_NESTED=y
CONFIG_VETH=y
CONFIG_MACVLAN=y
CONFIG_IPVLAN=y
CONFIG_DUMMY=y
CONFIG_BONDING=y
CONFIG_8021Q=y
CONFIG_VLAN_8021Q=y

# === USB/GADGET (for device passthrough) ===
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_F_RNDIS=y
CONFIG_USB_F_MASS_STORAGE=y

# === PERFORMANCE ===
CONFIG_CC_OPTIMIZE_FOR_SIZE=n
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_LTO_CLANG=y
CONFIG_LTO_CLANG_THIN=y
CONFIG_CLANG_VERSION=180000

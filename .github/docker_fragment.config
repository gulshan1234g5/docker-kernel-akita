# ============================================================
# DOCKER/CONTAINER KERNEL CONFIG — RESEARCH-BACKED
# Sources: moby/check-config.sh, AOSP android-6.1-base.config,
#          WildKernel r7, GKI-Custom (tomxi1997), KernelSU docs
# Device: Pixel 8a (akita) — GKI 6.1 (android14-6.1)
# ============================================================

# === IPC (Required for containers) ===
# SYSVIPC is DISABLED in GKI base — must enable
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y

# === CORE NAMESPACES (Required for Docker) ===
# USER_NS is DISABLED in GKI base — must enable
CONFIG_USER_NS=y
# Other namespaces (NET_NS/PID_NS/IPC_NS/UTS_NS) are already in GKI base

# === CONTROL GROUPS (Docker mandatory) ===
# Many CGROUP options are DISABLED in GKI base — enable them
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_MISC=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_NET_CLS_CGROUP=y
# MEMCG + CPUSETS + BLK_CGROUP already in GKI base

# === OVERLAY FS (Docker image layers) ===
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_METACOPY=y

# === BLOCK DEVICE (Docker storage drivers) ===
CONFIG_DM_THIN_PROVISIONING=y
CONFIG_BLK_DEV_NBD=y

# === VIRTUAL NETWORKING (Docker net) ===
CONFIG_VETH=y
CONFIG_BRIDGE_VLAN_FILTERING=y
CONFIG_IPVLAN=y
CONFIG_MACVLAN=y
CONFIG_VXLAN=y
CONFIG_TUN=y

# === NETFILTER — IPTABLES (Docker NAT/firewall) ===
# ip6_NF_NAT is DISABLED in GKI base — must enable
CONFIG_IP6_NF_NAT=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP6_NF_MANGLE=y
CONFIG_IP_NF_RAW=y
CONFIG_IP6_NF_RAW=y
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_TARGET_CHECKSUM=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_TCPMSS=y
CONFIG_NETFILTER_XT_TARGET_NFLOG=y
CONFIG_NETFILTER_XT_TARGET_LOG=y
CONFIG_NETFILTER_XT_TARGET_REJECT=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y

# === NFTABLES (Modern iptables replacement) ===
CONFIG_NF_TABLES=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_CT=y
CONFIG_NFT_FIB=y
CONFIG_NFT_FIB_IPV4=y
CONFIG_NFT_FIB_IPV6=y

# === IPVS (Docker Swarm load balancing) ===
# IP_VS is DISABLED in GKI base — must enable
CONFIG_IP_VS=y
CONFIG_IP_VS_NFCT=y
CONFIG_IP_VS_RR=y
CONFIG_IP_VS_WRR=y
CONFIG_IP_VS_SH=y
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y

# === IPSET (UFW/Fail2ban/Docker) ===
# IP_SET is DISABLED in GKI base — must enable
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_NETLINK_QUEUE=y
CONFIG_NETFILTER_NETLINK_LOG=y

# === ADVANCED ROUTING ===
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y

# === BONDING + VLAN ===
CONFIG_BONDING=y
CONFIG_VLAN_8021Q=y

# === FHANDLE (Required by Docker/systemd) ===
# DISABLED in GKI base — must enable
CONFIG_FHANDLE=y

# === KEYS (Required by Docker) ===
# Already in GKI base, but explicitly ensure
CONFIG_KEYS=y

# === NETWORK PERFORMANCE (Research-backed) ===
# FQ_CODEL as default qdisc (Docker recommends this for general use)
# Use CONFIG_DEFAULT_FQ_CODEL=y instead of CONFIG_DEFAULT_NET_SCH="fq_codel"
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_DEFAULT_FQ_CODEL=y
CONFIG_NET_SCH_SFQ=y
CONFIG_NET_SCH_FQ=y

# BBR congestion control (Google research — best for throughput)
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# === PREEMPTION MODEL ===
# GKI base already has CONFIG_PREEMPT=y
# Do NOT set CONFIG_PREEMPT_VOLUNTARY — it conflicts with PREEMPT
# Removing both to let GKI base decide

# === I/O SCHEDULER ===
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_MQ_IOSCHED_BFQ=y
CONFIG_DEFAULT_MQ_IOSCHED="bfq"

# === ZRAM + ZSWAP (Memory optimization) ===
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_MULTI_COMP=y
CONFIG_ZRAM_BACKEND_ZSTD=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_ZSWAP_SHRINKER_DEFAULT_ON=y
CONFIG_SWAP=y

# === TRANSPARENT HUGEPAGES ===
CONFIG_TRANSPARENT_HUGEPAGE=y
# Use MADVISE mode (recommended for Android — avoids performance regressions)
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_THP_SWAP=y

# === MEMORY MANAGEMENT ===
CONFIG_CMA=y
CONFIG_CMA_SIZE_MBYTES=64
CONFIG_CONTIG_ALLOC=y
CONFIG_PAGE_REPORTING=y
CONFIG_KSM=y
CONFIG_DEFAULT_MMAP_MIN_ADDR=32768

# === SCHEDULER ===
CONFIG_SCHED_AUTOGROUP=y
CONFIG_SCHED_TUNE=y
CONFIG_HZ_300=y
CONFIG_HZ=300

# === BPF (Advanced networking/tracing) ===
# Already in GKI base but ensure BPF_LSM
CONFIG_BPF_LSM=y

# === SECURITY (Beyond GKI base) ===
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_YAMA=y

# === FILESYSTEMS (Docker storage backends) ===
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_XFS_FS=y
CONFIG_F2FS_FS=y
CONFIG_NTFS3_FS=y

# === CRYPTO (Docker content trust) ===
CONFIG_CRYPTO_LZO=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_ZSTD=y

# === TMPFS XATTR (NixOS/home-manager support) ===
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y

# === FIRMWARE ===
CONFIG_FW_LOADER_USER_HELPER=y
CONFIG_FW_LOADER_COMPRESS=y

# === PROCESS ACCOUNTING ===
CONFIG_TASK_DELAY_ACCT=y
CONFIG_TASK_XACCT=y
CONFIG_TASK_IO_ACCOUNTING=y

# === USB/GADGET (device passthrough) ===
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_F_RNDIS=y
CONFIG_USB_F_MASS_STORAGE=y

# === PERFORMANCE ===
# Use PERFORMANCE optimization (not SIZE optimization)
# CONFIG_CC_OPTIMIZE_FOR_SIZE is not set
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
# LTO=thin is safe for GitHub 7GB runner
CONFIG_LTO_CLANG=y
CONFIG_LTO_CLANG_THIN=y
# CLANG_VERSION is auto-detected — don't hardcode
